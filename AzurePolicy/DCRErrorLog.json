{
  "properties": {
    "displayName": "Enable Error Log DCR Logging to Log Analytics",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "Ensures that the Data Collection Rule (DCR) collects Error‑level logs and routes them to the designated Log Analytics workspace. This setting provides complete visibility into system and application failures, supports troubleshooting, and maintains consistent monitoring coverage across resources.",
    "metadata": {
      "category": "Monitoring",
      "createdBy": "0e8b455c-b0b6-412a-9178-217611345107",
      "createdOn": "2026-01-29T12:10:42.2604259Z",
      "updatedBy": "0e8b455c-b0b6-412a-9178-217611345107",
      "updatedOn": "2026-01-29T12:29:24.7593983Z"
    },
    "version": "1.0.0",
    "parameters": {
      "workspaceResourceId": {
        "type": "String",
        "metadata": {
          "displayName": "Primary Log Analytics workspace",
          "description": "If this workspace is outside of the scope of the assignment you must manually grant 'Log Analytics Contributor' permissions (or similar) to the policy assignment's principal ID.",
          "strongType": "omsWorkspace",
          "assignPermissions": true
        }
      }
    },
    "policyRule": {
      "if": {
        "field": "type",
        "equals": "Microsoft.Insights/dataCollectionRules"
      },
      "then": {
        "effect": "deployIfNotExists",
        "details": {
          "type": "Microsoft.Insights/dataCollectionRules/providers/diagnosticSettings",
          "existenceCondition": {
            "field": "name",
            "equals": "[concat(field('name'), '/Microsoft.Insights/DCR-error-log-to-log-analytics')]"
          },
          "roleDefinitionIds": [
            "/providers/Microsoft.Authorization/roleDefinitions/749f88d5-cbae-40b8-bcfc-e573ddc772fa",
            "/providers/Microsoft.Authorization/roleDefinitions/92009123-610d-4452-8510-923a54d3d294"
          ],
          "deployment": {
            "properties": {
              "mode": "incremental",
              "template": {
                "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
                "contentVersion": "1.0.0.0",
                "parameters": {
                  "workspaceResourceId": {
                    "type": "string"
                  },
                  "dcrName": {
                    "type": "string"
                  }
                },
                "resources": [
                  {
                    "type": "Microsoft.Insights/dataCollectionRules/providers/diagnosticSettings",
                    "apiVersion": "2021-05-01-preview",
                    "name": "[concat(parameters('dcrName'), '/Microsoft.Insights/DCR-error-log-to-log-analytics')]",
                    "properties": {
                      "workspaceId": "[parameters('workspaceResourceId')]",
                      "logs": [
                        {
                          "category": "LogErrors",
                          "enabled": true
                        }
                      ]
                    }
                  }
                ]
              },
              "parameters": {
                "workspaceResourceId": {
                  "value": "[parameters('workspaceResourceId')]"
                },
                "dcrName": {
                  "value": "[field('name')]"
                }
              }
            }
          }
        }
      }
    },
    "versions": [
      "1.0.0"
    ]
  },
  "id": "/providers/microsoft.management/managementgroups/production/providers/Microsoft.Authorization/policyDefinitions/068c3a6c1ac0487680e0ee8c",
  "type": "Microsoft.Authorization/policyDefinitions",
  "name": "068c3a6c1ac0487680e0ee8c",
